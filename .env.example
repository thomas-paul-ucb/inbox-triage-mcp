# Anthropic API key for the classifier (console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key_here

# OAuth client credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here

# Gmail MCP server endpoint (official Google MCP server)
GMAIL_MCP_SERVER_URL=https://gmailmcp.googleapis.com/mcp/v1

# Local redirect URI for the OAuth flow (must match what's registered in Cloud Console)
OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback